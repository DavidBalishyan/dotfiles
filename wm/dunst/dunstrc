# Tokyo Night dunst config - regular notifications + volume/brightness OSD.

[global]
    monitor = 0
    follow = mouse

    # Centered OSD-style popup
    origin = top-center
    offset = 0x60
    width = 320
    height = (0, 120)
    notification_limit = 3

    progress_bar = true
    progress_bar_height = 12
    progress_bar_frame_width = 0
    progress_bar_min_width = 296
    progress_bar_max_width = 296

    gap_size = 6
    separator_height = 0
    padding = 12
    horizontal_padding = 14
    frame_width = 2
    corner_radius = 8

    font = JetBrainsMono Nerd Font 11
    line_height = 0
    markup = full
    format = "<b>%s</b>"
    alignment = center
    vertical_alignment = center
    icon_position = left
    min_icon_size = 24
    max_icon_size = 40

    frame_color = "#7aa2f7"
    highlight = "#7aa2f7"
    mouse_left_click = close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#1a1b26"
    foreground = "#c0caf5"
    frame_color = "#7aa2f7"
    timeout = 2

[urgency_normal]
    background = "#1a1b26"
    foreground = "#c0caf5"
    frame_color = "#7aa2f7"
    timeout = 6

[urgency_critical]
    background = "#1a1b26"
    foreground = "#c0caf5"
    frame_color = "#f7768e"
    timeout = 0
